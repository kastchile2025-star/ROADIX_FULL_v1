# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=roadix_user
DB_PASSWORD=roadix_dev_pass
DB_DATABASE=roadix

# Auth
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# App
APP_URL=http://localhost:5173
CORS_ORIGINS=https://app.roadix.cl,https://roadix.cl
PORT=3000

# Email (SendGrid) — Phase 4
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=notificaciones@roadix.cl

# Google Cloud Storage — Phase 2
# GCS_BUCKET=roadix-files
# GCS_PROJECT_ID=
# GCS_KEY_FILE=

# Stripe — Phase later
# STRIPE_SECRET_KEY=sk_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Flow Billing
FLOW_ENV=sandbox
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://sandbox.flow.cl/api
FLOW_COMMERCE_ID=
FLOW_RETURN_URL=https://app.roadix.cl/billing/return
FLOW_CONFIRM_URL=http://localhost:3000/billing/flow/webhook

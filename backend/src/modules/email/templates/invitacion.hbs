{{#> layouts/base}}
<h2 style="color:#1a1a2e; margin-bottom:16px;">¡Te han invitado a Roadix!</h2>
<p>Hola <strong>{{nombre}}</strong>,</p>
<p>Has sido invitado/a a unirte al taller <strong>{{taller_nombre}}</strong> en Roadix como <strong>{{rol}}</strong>.</p>
<p>Haz clic en el siguiente botón para activar tu cuenta y crear tu contraseña:</p>
<div style="text-align:center; margin:24px 0;">
  <a href="{{invite_url}}" style="display:inline-block;background:#6366f1;color:#fff;padding:14px 28px;border-radius:8px;text-decoration:none;font-weight:bold;">
    Activar mi Cuenta
  </a>
</div>
<p style="font-size:13px;color:#666;">Este enlace expira en 48 horas.</p>
{{/layouts/base}}

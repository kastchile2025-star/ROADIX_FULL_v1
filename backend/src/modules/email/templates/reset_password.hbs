{{#> layouts/base}}
<h2 style="color:#1a1a2e; margin-bottom:16px;">Restablecer Contraseña</h2>
<p>Hola <strong>{{nombre}}</strong>,</p>
<p>Recibimos una solicitud para restablecer tu contraseña en <strong>{{taller_nombre}}</strong>.</p>
<p>Haz clic en el siguiente botón para crear una nueva contraseña:</p>
<div style="text-align:center; margin:24px 0;">
  <a href="{{reset_url}}" style="display:inline-block;background:#6366f1;color:#fff;padding:14px 28px;border-radius:8px;text-decoration:none;font-weight:bold;">
    Restablecer Contraseña
  </a>
</div>
<p style="font-size:13px;color:#666;">Este enlace expira en 1 hora. Si no solicitaste este cambio, puedes ignorar este correo.</p>
{{/layouts/base}}

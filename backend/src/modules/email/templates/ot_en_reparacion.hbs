{{#> layout}}
<h2>Su Vehículo está en Reparación</h2>
<p>Hola <strong>{{cliente_nombre}}</strong>,</p>
<p>Le informamos que su vehículo ya se encuentra en proceso de reparación.</p>
<div class="info-box">
  <dl>
    <dt>Orden de Trabajo:</dt><dd>{{numero_ot}}</dd>
    <dt>Vehículo:</dt><dd>{{vehiculo_marca}} {{vehiculo_modelo}} — {{vehiculo_patente}}</dd>
    <dt>Mecánico Asignado:</dt><dd>{{mecanico_nombre}}</dd>
  </dl>
</div>
{{#if portal_url}}
<p style="text-align: center; margin-top: 16px;">
  <a href="{{portal_url}}" class="btn">Seguir Estado en Línea</a>
</p>
{{/if}}
{{/layout}}
